  code        = {https://github.com/orion-junkins/river-level-forecasting},
  video       = {https://www.youtube.com/watch?v=s9dqKgClDeo},
  abstract    = {We developed an efficient and scalable river flow forecasting approach using an ensemble of spatially distributed GRUs. Validated with a 110-day simulation for three rivers, our method outperformed available NOAA forecasts with a 2.85% reduction in MAPE for 24-hour predictions.},
