@article{junkins2026cgns,
  abbr        = {HPG},
  title       = {Compatibility-Guided Neighbor Selection for {ReSTIR}},
  author      = {Junkins, Orion and Kettunen, Markus and Lin, Daqi and Ramamoorthi, Ravi and Wyman, Chris},
  journal     = {Proceedings of the ACM on Computer Graphics and Interactive Techniques},
  volume      = {9},
  number      = {4},
  year        = {2026},
  publisher   = {ACM},
  note        = {To appear at HPG 2026},
  abstract    = {We propose a geometry-based pixel compatibility heuristic and use it to guide spatial neighbor selection in ReSTIR via weighted reservoir sampling, as a drop-in replacement for prior work. Our approach reduces SMAPE by 6--29% and temporal covariance by 22--49% at 2--5% overhead, improving the Pareto frontier of ReSTIR's error--correlation tradeoff.},
  selected    = {true},
  website     = {/projects/1_project/},
  bibtex_show = {true}
}

