  abbr        = {ICFSP},
  title       = {Short-Term River Forecasting with a Stacked Ensemble of Tributary Models},
  author      = {Donnelly, Patrick J. and Junkins, Orion},
  booktitle   = {2022 7th International Conference on Frontiers of Signal Processing (ICFSP)},
  year        = {2022},
